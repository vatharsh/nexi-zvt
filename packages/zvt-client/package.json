{
  "name": "@accurateitsolutionorg/nexi-zvt-client",
  "version": "0.2.0",
  "description": "ZVT protocol client and mock terminal for CCV/Nexi payment terminals (A77) over TCP.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "zvt",
    "payment-terminal",
    "nexi",
    "ccv",
    "a77"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
